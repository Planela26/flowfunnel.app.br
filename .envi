# ============================================
# FlowFunnel - Environment Variables Export
# Generated for deployment in another platform
# ============================================

# --------------------------------------------
# Database
# Preencha com os dados do PostgreSQL do novo ambiente
# --------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/whatsapp_funnel"
# NEON_DATABASE_URL: alternativa se usar Neon (opcional)
NEON_DATABASE_URL="postgresql://user:password@host:5432/whatsapp_funnel"

# --------------------------------------------
# NextAuth
# --------------------------------------------
# NEXTAUTH_SECRET: gere uma chave secreta forte (ex: openssl rand -base64 32)
NEXTAUTH_SECRET="COLE_AQUI_SUA_CHAVE_SECRETA_FORTE"
NEXTAUTH_URL="https://flowfunnel.app.br"

# --------------------------------------------
# App URLs (usadas pelo frontend para links e callbacks)
# --------------------------------------------
NEXT_PUBLIC_APP_URL="https://flowfunnel.app.br"
NEXT_PUBLIC_SITE_URL="https://flowfunnel.app.br"
BASE_URL="https://flowfunnel.app.br"
BASE_PATH=""

# --------------------------------------------
# Google OAuth (login com Google)
# --------------------------------------------
GOOGLE_CLIENT_ID="COLE_AQUI"
GOOGLE_CLIENT_SECRET="COLE_AQUI"

# --------------------------------------------
# Meta / Facebook API / Pixel / Conversions API
# --------------------------------------------
